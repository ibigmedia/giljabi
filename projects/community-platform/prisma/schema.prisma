// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MEMBER
  EDITOR
  ADMIN
}

model Profile {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text"))
  userId      String   @unique // Supabase Auth user id 매핑
  username    String   @unique
  email       String?  @unique
  avatarUrl   String?
  coverUrl    String?
  bio         String?
  church      String?  // 출석교회 (교단포함)
  churchRole  String?  // 직분 (목사, 전도사, 장로, 권사, 집사, 성도)
  isApproved  Boolean  @default(false) // 관리자 승인 여부
  role        UserRole @default(MEMBER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       Post[]
  blogPosts   BlogPost[]
  comments    Comment[]
  likes       PostLike[]
  memberships GroupMember[]
  followers   Follow[]      @relation("Followers")
  following   Follow[]      @relation("Following")

  notificationsSent     Notification[] @relation("NotificationsSent")
  notificationsReceived Notification[] @relation("NotificationsReceived")

  chatParticipants ChatParticipant[]
  chatMessages     ChatMessage[]
}

model Follow {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text"))
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  Profile @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following Profile @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Post {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  content   String
  mediaUrl  String?
  isPinned  Boolean  @default(false)
  authorId  String
  author    Profile  @relation(fields: [authorId], references: [id])
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments      Comment[]
  likes         PostLike[]
  notifications Notification[]
}

model Comment {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  content   String
  authorId  String
  author    Profile  @relation(fields: [authorId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]
}

model PostLike {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, profileId])
}

model Group {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text"))
  name        String
  description String?
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members GroupMember[]
  posts   Post[]
}

model GroupMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  role      String   @default("MEMBER") // ADMIN, MODERATOR, MEMBER
  createdAt DateTime @default(now())

  @@unique([groupId, profileId])
}

model Notification {
  id         String   @id @default(dbgenerated("gen_random_uuid()::text"))
  actorId    String
  receiverId String
  type       String // 'LIKE', 'COMMENT', 'FOLLOW'
  postId     String?
  commentId  String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  actor    Profile  @relation("NotificationsSent", fields: [actorId], references: [id], onDelete: Cascade)
  receiver Profile  @relation("NotificationsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  post     Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment  Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model ChatChannel {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ChatParticipant[]
  messages     ChatMessage[]
}

model ChatParticipant {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  channelId String
  profileId String
  createdAt DateTime @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  profile Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([channelId, profileId])
}

model ChatMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  channelId String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  Profile     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  title     String
  excerpt   String?
  content   String
  mediaUrl  String?
  isPublished Boolean @default(false)
  authorId  String
  author    Profile  @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
